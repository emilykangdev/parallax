{
  "name": "parallax",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Sketch → polished comic render loop on iii.dev",
  "scripts": {
    "dev": "iii --config config.yaml",
    "dev:gemini": "bash scripts/dotenvx-wrap.sh tsx workers/provider-gemini/src/index.ts",
    "dev:render": "bash scripts/dotenvx-wrap.sh tsx workers/parallax-render/src/index.ts",
    "dev:comprehension": "bash scripts/dotenvx-wrap.sh tsx workers/parallax-comprehension/src/index.ts",
    "push": "bash scripts/dotenvx-wrap.sh tsx scripts/push.ts",
    "typecheck": "npm --prefix workers/provider-gemini run typecheck && npm --prefix workers/parallax-render run typecheck && npm --prefix workers/parallax-comprehension run typecheck && tsc -p scripts/tsconfig.json",
    "smoke": "bash scripts/dotenvx-wrap.sh tsx scripts/smoke.ts",
    "ready": "bash scripts/ready.sh",
    "review": "bash scripts/review.sh",
    "validate-plan": "bash scripts/validate-plan.sh",
    "env:encrypt": "dotenvx encrypt -f .env",
    "prepare": "husky"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.65.2",
    "@dotenvx/dotenvx-ops": "^0.46.1",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
