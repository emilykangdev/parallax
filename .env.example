# Required env for Parallax. Real values are managed with dotenvx-ops (encrypted
# at rest in .env; private keys live in your Ops login, never on disk).
#
# Onboarding:
#   1. curl -sfS https://dotenvx.sh/ops | sh
#   2. dotenvx-ops login
#   3. npx dotenvx set GEMINI_API_KEY <value> -f .env
#      npx dotenvx set PARALLAX_TOKEN <value> -f .env
# Then run a worker with env injected:  npm run dev:gemini  /  npm run dev:render
#
# Local-only plaintext overrides (never committed) go in .env.local instead.

# Google AI Studio key for Gemini 2.5 Flash Image ("nano banana").
GEMINI_API_KEY=

# Shared bearer guarding POST /api/render. Random >= 32 chars, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PARALLAX_TOKEN=

# Read-only token for the browser WS listener (:3112, auth::browser). Embedded
# in the /scratch HTML, so keep it SEPARATE from PARALLAX_TOKEN — it must never
# grant render::create. Generate the same way as PARALLAX_TOKEN.
PARALLAX_BROWSER_TOKEN=

# Engine bus URL the workers connect to (non-secret).
III_URL=ws://localhost:8112
